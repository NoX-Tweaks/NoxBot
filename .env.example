DISCORD_TOKEN=coloque_o_token_do_bot_aqui
DEV_IDS=seu_id_do_discord_aqui
MONGO_URI=coloque_a_url_do_mongodb_aqui
MONGO_DB_NAME=nox_bot

# Use apenas se seu MongoDB pedir TLS/certificados.
# Se os arquivos estiverem em ./certs com estes nomes, o bot detecta sozinho:
# ca-certificate.crt, certificate.pem, private-key.key
MONGO_TLS=false
MONGO_TLS_ALLOW_INVALID_CERTIFICATES=false
MONGO_CA_FILE=
MONGO_CERT_FILE=
MONGO_KEY_FILE=
